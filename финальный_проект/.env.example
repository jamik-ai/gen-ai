# Скопируй этот файл в .env и заполни своими значениями

# Вариант A — OpenAI напрямую
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4.1-mini

# Вариант B — DeepSeek / локальный или корпоративный LLM-сервер (vLLM, Ollama, etc.)
# LLM_BASE_URL=https://api.deepseek.com
# LLM_AUTH_TOKEN=your-token
# LLM_MODEL=deepseek-chat
# LLM_TIMEOUT=200

# Включить цепочку рассуждений (для Qwen3 и аналогов)
# LLM_THINKING=off
